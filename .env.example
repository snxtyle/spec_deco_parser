# HuggingFace Configuration
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# GCP Configuration (for GCS bucket access)
# Option 1: Service Account JSON key file path
GCP_SERVICE_ACCOUNT_KEY=/path/to/your/service-account-key.json

# Option 2: GCP credentials directly (base64 encoded)
GCP_CREDENTIALS_B64=your_base64_encoded_credentials

# Option 3: GCP project ID (when using Application Default Credentials)
GCP_PROJECT_ID=your_project_id
